---
import { LANGS, isLang, DEFAULT_LANG, type Lang } from "../../lib/i18n";
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Hero from "../../components/Hero.astro";
import VendorMarquee from "../../components/VendorMarquee.astro";
import ProblemFraming from "../../components/ProblemFraming.astro";
import Pillars from "../../components/Pillars.astro";
import WhyUs from "../../components/WhyUs.astro";
import Partners from "../../components/Partners.astro";
import Stats from "../../components/Stats.astro";
import Testimonials from "../../components/Testimonials.astro";
import FinalCta from "../../components/FinalCta.astro";
import Footer from "../../components/Footer.astro";

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}
const { lang: raw } = Astro.params;
const lang: Lang = isLang(raw) ? raw : DEFAULT_LANG;
---

<Base lang={lang} page="home">
  <Nav lang={lang} page="home" />
  <main id="main">
    <Hero lang={lang} />
    <VendorMarquee lang={lang} />
    <ProblemFraming lang={lang} />
    <Pillars lang={lang} variant="preview" />
    <WhyUs lang={lang} />
    <Partners lang={lang} />
    <Stats lang={lang} />
    <Testimonials lang={lang} />
    <FinalCta lang={lang} />
  </main>
  <Footer lang={lang} page="home" />
</Base>
