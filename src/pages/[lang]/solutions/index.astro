---
import { LANGS, isLang, DEFAULT_LANG, getContent, type Lang } from "../../../lib/i18n";
import Base from "../../../layouts/Base.astro";
import Nav from "../../../components/Nav.astro";
import PageHeader from "../../../components/PageHeader.astro";
import ScrollStory from "../../../components/ScrollStory.astro";
import ProblemFraming from "../../../components/ProblemFraming.astro";
import FinalCta from "../../../components/FinalCta.astro";
import Footer from "../../../components/Footer.astro";

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}
const { lang: raw } = Astro.params;
const lang: Lang = isLang(raw) ? raw : DEFAULT_LANG;
const c = getContent(lang);
---

<Base lang={lang} page="solutions">
  <Nav lang={lang} page="solutions" />
  <main id="main">
    <PageHeader lang={lang} page="solutions" eyebrow={c.process.eyebrow} title={c.process.title} lead={c.process.sub} />
    <ScrollStory lang={lang} hideHeader />
    <ProblemFraming lang={lang} />
    <FinalCta lang={lang} />
  </main>
  <Footer lang={lang} page="solutions" />
</Base>
