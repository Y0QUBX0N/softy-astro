---
import { LANGS, isLang, DEFAULT_LANG, getContent, type Lang } from "../../../../lib/i18n";
import { CATEGORIES, productsByCategory, getCategory, productLogo } from "../../../../lib/catalog";
import { productCopy } from "../../../../lib/catalog-i18n";
import { pageUrl } from "../../../../lib/nav";
import Base from "../../../../layouts/Base.astro";
import Nav from "../../../../components/Nav.astro";
import FinalCta from "../../../../components/FinalCta.astro";
import Footer from "../../../../components/Footer.astro";

export function getStaticPaths() {
  return LANGS.flatMap((lang) =>
    CATEGORIES.map((cat) => ({ params: { lang, category: cat.slug } }))
  );
}

const { lang: rawLang, category: rawCat } = Astro.params;
const lang: Lang = isLang(rawLang) ? rawLang : DEFAULT_LANG;
const category = getCategory(rawCat ?? "");
if (!category) return Astro.redirect(`/${lang}/catalog/`);

const c = getContent(lang);
const meta = c.catalog.categories[category.key];
const products = productsByCategory(category.slug);
const catalogHref = pageUrl(lang, "catalog");
---

<Base lang={lang} page="catalog" slug={`catalog/${category.slug}`} metaTitle={`${meta.name} | Softy LLC`} metaDescription={meta.desc}>
  <Nav lang={lang} page="catalog" />
  <main id="main">
    <section class="border-t border-hairline pb-8 pt-32 md:pt-40">
      <div class="container-x">
        <nav aria-label="Breadcrumb" class="mb-8 flex items-center gap-2 text-sm text-muted">
          <a href={catalogHref} class="transition-colors hover:text-accent">{c.catalog.eyebrow}</a>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6"/></svg>
          <span class="text-primary">{meta.name}</span>
        </nav>
        <span class="eyebrow">{c.catalog.eyebrow} · {c.catalog.productCount(products.length)}</span>
        <h1 class="h2 mt-5 text-balance">{meta.name}</h1>
        <p class="mt-6 max-w-prose text-lg text-muted">{meta.desc}</p>
      </div>
    </section>

    <section class="pb-24 pt-10 md:pb-32">
      <div class="container-x">
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {
            products.map((p) => (
              <a
                href={`${catalogHref}${category.slug}/${p.slug}/`}
                class="card-3d reveal group flex flex-col gap-5 overflow-hidden rounded-2xl border border-hairline bg-ink-2/40 p-6 hover:border-accent/40 hover:bg-ink-2/70"
                data-cursor
              >
                <div class="flex h-32 items-center justify-center rounded-xl bg-paper p-6 md:h-36">
                  <img src={productLogo(p.slug)} alt={p.vendor} loading="lazy" decoding="async" width="220" height="80" class="max-h-20 w-auto max-w-[82%] object-contain md:max-h-[88px]" />
                </div>
                <div class="flex-1">
                  <div class="font-mono text-[11px] uppercase tracking-eyebrow text-muted">{p.vendor}</div>
                  <h3 class="mt-2 text-xl font-medium leading-tight tracking-tight">{p.name}</h3>
                  <p class="mt-3 line-clamp-3 text-[15px] leading-relaxed text-secondary">{productCopy(p.slug, lang).tagline}</p>
                </div>
                <div class="flex items-center justify-between border-t border-hairline pt-4 text-sm">
                  <span class="text-muted">{p.os.slice(0, 2).join(" · ")}{p.os.length > 2 ? ` +${p.os.length - 2}` : ""}</span>
                  <span class="flex items-center gap-1 text-accent transition-transform group-hover:translate-x-1">
                    {c.common.learnMore}
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                  </span>
                </div>
              </a>
            ))
          }
        </div>

        <div class="reveal mt-16 flex items-center justify-center">
          <a href={catalogHref} class="btn btn-ghost" data-cursor>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M19 12H5M11 18l-6-6 6-6"/></svg>
            {c.catalog.allCategories}
          </a>
        </div>
      </div>
    </section>

    <FinalCta lang={lang} />
  </main>
  <Footer lang={lang} page="catalog" />
</Base>
