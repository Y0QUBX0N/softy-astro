---
import { LANGS, isLang, DEFAULT_LANG, getContent, type Lang } from "../../../lib/i18n";
import { CATEGORIES, productsByCategory } from "../../../lib/catalog";
import { pageUrl } from "../../../lib/nav";
import Base from "../../../layouts/Base.astro";
import Nav from "../../../components/Nav.astro";
import PageHeader from "../../../components/PageHeader.astro";
import FinalCta from "../../../components/FinalCta.astro";
import Footer from "../../../components/Footer.astro";

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}
const { lang: raw } = Astro.params;
const lang: Lang = isLang(raw) ? raw : DEFAULT_LANG;
const c = getContent(lang);

const CATEGORY_ICONS: Record<string, string> = {
  office:
    '<rect x="3" y="6" width="18" height="14" rx="2"/><path d="M3 10h18M8 6V4h8v2"/>',
  antivirus:
    '<path d="M12 3l8 4v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V7z"/><path d="M9 12l2 2 4-4"/>',
  design:
    '<path d="M14 4l6 6-12 12H2v-6L14 4z"/><path d="M12 6l6 6"/>',
  "network-security":
    '<rect x="3" y="11" width="18" height="10" rx="2"/><path d="M7 11V8a5 5 0 0110 0v3"/><circle cx="12" cy="16" r="1.5"/>',
  "backup-tools":
    '<rect x="3" y="4" width="18" height="6" rx="1"/><rect x="3" y="14" width="18" height="6" rx="1"/><circle cx="7" cy="7" r="1" fill="currentColor"/><circle cx="7" cy="17" r="1" fill="currentColor"/>',
};
---

<Base lang={lang} page="catalog">
  <Nav lang={lang} page="catalog" />
  <main id="main">
    <PageHeader lang={lang} page="catalog" eyebrow={c.catalog.eyebrow} title={c.catalog.title} lead={c.catalog.sub} />

    <section class="py-20 md:py-28">
      <div class="container-x">
        <div data-stagger class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {
            CATEGORIES.map((cat) => {
              const meta = c.catalog.categories[cat.key];
              const count = productsByCategory(cat.slug).length;
              return (
                <a
                  href={`${pageUrl(lang, "catalog")}${cat.slug}/`}
                  class="card-3d group relative flex flex-col gap-5 overflow-hidden rounded-2xl border border-hairline bg-ink-2/40 p-7 hover:border-accent/40 hover:bg-ink-2/70"
                  data-cursor
                >
                  <span class="grid h-12 w-12 place-items-center rounded-xl border border-hairline text-accent transition-colors duration-300 group-hover:border-accent/60 group-hover:bg-accent/10">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={CATEGORY_ICONS[cat.slug]} />
                  </span>
                  <div class="flex-1">
                    <h3 class="text-2xl font-medium leading-tight tracking-tight">{meta.name}</h3>
                    <p class="mt-3 text-[15px] leading-relaxed text-secondary">{meta.desc}</p>
                  </div>
                  <div class="mt-2 flex items-center justify-between border-t border-hairline pt-4 text-sm">
                    <span class="font-mono text-xs uppercase tracking-eyebrow text-muted">{c.catalog.productCount(count)}</span>
                    <span class="flex items-center gap-1 text-accent opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                      {c.common.learnMore}
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                    </span>
                  </div>
                </a>
              );
            })
          }
        </div>
      </div>
    </section>

    <FinalCta lang={lang} />
  </main>
  <Footer lang={lang} page="catalog" />
</Base>
