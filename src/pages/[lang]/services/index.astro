---
import { LANGS, isLang, DEFAULT_LANG, getContent, type Lang } from "../../../lib/i18n";
import Base from "../../../layouts/Base.astro";
import Nav from "../../../components/Nav.astro";
import PageHeader from "../../../components/PageHeader.astro";
import Pillars from "../../../components/Pillars.astro";
import Partners from "../../../components/Partners.astro";
import EngagementModels from "../../../components/EngagementModels.astro";
import FinalCta from "../../../components/FinalCta.astro";
import Footer from "../../../components/Footer.astro";

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}
const { lang: raw } = Astro.params;
const lang: Lang = isLang(raw) ? raw : DEFAULT_LANG;
const c = getContent(lang);
---

<Base lang={lang} page="services">
  <Nav lang={lang} page="services" />
  <main id="main">
    <PageHeader lang={lang} page="services" eyebrow={c.pillars.eyebrow} title={c.pillars.title} lead={c.pageMeta.services.description} />
    <Pillars lang={lang} variant="full" hideHeader />
    <Partners lang={lang} />
    <EngagementModels lang={lang} />
    <FinalCta lang={lang} />
  </main>
  <Footer lang={lang} page="services" />
</Base>
