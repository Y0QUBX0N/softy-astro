---
import { LANGS, isLang, DEFAULT_LANG, getContent, type Lang } from "../../../lib/i18n";
import Base from "../../../layouts/Base.astro";
import Nav from "../../../components/Nav.astro";
import PageHeader from "../../../components/PageHeader.astro";
import About from "../../../components/About.astro";
import Stats from "../../../components/Stats.astro";
import Testimonials from "../../../components/Testimonials.astro";
import FinalCta from "../../../components/FinalCta.astro";
import Footer from "../../../components/Footer.astro";

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}
const { lang: raw } = Astro.params;
const lang: Lang = isLang(raw) ? raw : DEFAULT_LANG;
const c = getContent(lang);
---

<Base lang={lang} page="about">
  <Nav lang={lang} page="about" />
  <main id="main">
    <PageHeader lang={lang} page="about" eyebrow={c.about.eyebrow} title={c.about.title} />
    <About lang={lang} hideHeader />
    <Stats lang={lang} />
    <Testimonials lang={lang} />
    <FinalCta lang={lang} />
  </main>
  <Footer lang={lang} page="about" />
</Base>
