---
import { getContent, type Lang } from "../lib/i18n";
const { lang } = Astro.props as { lang: Lang };
const c = getContent(lang);
---

<section class="relative overflow-hidden border-t border-hairline py-28 md:py-36">
  <div
    class="pointer-events-none absolute inset-0 -z-10"
    style="background:radial-gradient(80% 120% at 50% 120%, rgba(0,217,163,0.18) 0%, rgba(14,16,20,0) 60%)"
  >
  </div>
  <div class="container-x text-center">
    <h2 class="reveal mx-auto max-w-[18ch] text-balance" style="font-size:clamp(40px,6vw,88px);font-weight:500;letter-spacing:-0.03em;line-height:1.02">
      {c.finalCta.title}
    </h2>
    <p class="reveal body-lg mx-auto mt-7 max-w-xl text-secondary">{c.finalCta.sub}</p>
    <div class="reveal mt-10 flex flex-wrap justify-center gap-4">
      <a href="tel:+998956400404" class="btn btn-accent" data-cursor data-magnetic="0.3">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.9v3a2 2 0 01-2.2 2 19.8 19.8 0 01-8.6-3 19.5 19.5 0 01-6-6 19.8 19.8 0 01-3-8.6A2 2 0 014.1 2h3a2 2 0 012 1.7c.1.9.3 1.8.6 2.6a2 2 0 01-.5 2.1L8.1 9.5a16 16 0 006 6l1.1-1.1a2 2 0 012.1-.5c.8.3 1.7.5 2.6.6a2 2 0 011.7 2z" /></svg>
        {c.finalCta.call}
      </a>
      <a href="https://t.me/Softy_admin" target="_blank" rel="noopener" class="btn btn-ghost" data-cursor>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M21.5 4L2.5 11.5l6 2 2.5 7 3-4.5 5 4z" /></svg>
        {c.finalCta.telegram}
      </a>
    </div>
  </div>
</section>
