---
import { getContent, type Lang } from "../lib/i18n";
const { lang, hideHeader = false } = Astro.props as { lang: Lang; hideHeader?: boolean };
const c = getContent(lang);
const a = c.about;
const values = c.values;
const team = c.team;
---

<section id="about" class="py-24 md:py-32">
  <div class={`container-x ${hideHeader ? "" : "grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:gap-20"}`}>
    {!hideHeader && (
      <div class="reveal lg:sticky lg:top-28 lg:self-start">
        <span class="eyebrow">{a.eyebrow}</span>
        <h2 class="h2 mt-6">{a.title}</h2>
      </div>
    )}
    <div class="reveal">
      <p class="max-w-3xl text-2xl font-medium leading-snug tracking-tight md:text-[30px] md:leading-[1.25]">{a.lead}</p>
      <div class="mt-10 flex flex-col gap-7 border-t border-hairline pt-10">
        {a.body.map((p) => <p class="body-lg max-w-[68ch] text-secondary">{p}</p>)}
      </div>
    </div>
  </div>
</section>

{values && (
  <section id="values" class="border-t border-hairline py-24 md:py-32">
    <div class="container-x">
      <div class="reveal max-w-prose">
        <span class="eyebrow">{values.eyebrow}</span>
        <h2 class="h2 mt-6">{values.title}</h2>
      </div>
      <div data-stagger class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4 lg:gap-5">
        {
          values.items.map((v, i) => (
            <div class="group flex flex-col gap-5 rounded-2xl border border-hairline bg-ink-2/30 p-8 transition-colors duration-500 hover:border-accent/40 hover:bg-ink-2/60">
              <span class="font-mono text-xs text-muted">0{i + 1}</span>
              <h3 class="text-[22px] font-medium leading-tight tracking-tight">{v.title}</h3>
              <p class="text-[16px] leading-relaxed text-primary/80">{v.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
)}

{team && (
  <section id="team" class="border-t border-hairline py-24 md:py-32">
    <div class="container-x">
      <div class="reveal max-w-prose">
        <span class="eyebrow">{team.eyebrow}</span>
        <h2 class="h2 mt-6">{team.title}</h2>
      </div>
      <div class="reveal mt-16 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {
          team.members.map((m) => {
            const initials = m.name.split(" ").map((s) => s[0]).slice(0, 2).join("");
            return (
              <article class="flex gap-6 rounded-2xl border border-hairline bg-ink-2/30 p-8 transition-colors duration-500 hover:border-accent/40">
                <span class="grid h-16 w-16 shrink-0 place-items-center rounded-full bg-gradient-to-br from-accent/25 to-accent/5 text-xl font-medium tracking-tight text-accent">
                  {initials}
                </span>
                <div class="flex-1">
                  <h3 class="text-[22px] font-medium leading-tight tracking-tight">{m.name}</h3>
                  <div class="mt-2 font-mono text-xs uppercase tracking-eyebrow text-accent">{m.role}</div>
                  <p class="mt-4 text-[16px] leading-relaxed text-primary/80">{m.bio}</p>
                </div>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>
)}
