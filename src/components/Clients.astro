---
import type { Lang } from "../lib/i18n";
import { CLIENTS } from "../lib/clients";
const { lang } = Astro.props as { lang: Lang };

const T: Record<Lang, { eyebrow: string; sub: string }> = {
  uz: { eyebrow: "Mijozlar", sub: "Davlat idoralari, banklar, telekom va yirik korxonalar" },
  ru: { eyebrow: "Клиенты", sub: "Госорганы, банки, телеком и крупные предприятия" },
  en: { eyebrow: "Clients", sub: "Government bodies, banks, telecom and large enterprises" },
  kk: { eyebrow: "Клиенттер", sub: "Мемлекеттік органдар, банктер, телеком және ірі кәсіпорындар" },
  ky: { eyebrow: "Кардарлар", sub: "Мамлекеттик органдар, банктер, телеком жана ири ишканалар" },
  tg: { eyebrow: "Муштариён", sub: "Мақомоти давлатӣ, бонкҳо, телеком ва корхонаҳои бузург" },
};
const c = T[lang];
// Doubled for a seamless infinite loop (GSAP shifts the track by -50%).
const loop = [...CLIENTS, ...CLIENTS];
---

<section id="clients" class="border-t border-hairline py-14 md:py-16">
  <div class="container-x">
    <div class="reveal flex flex-wrap items-baseline gap-x-4 gap-y-1">
      <span class="eyebrow">{c.eyebrow}</span>
      <span class="text-[15px] text-muted">{c.sub}</span>
    </div>
  </div>

  <!-- White rail so brand-coloured client logos read on the dark page. -->
  <div class="clients-mask relative mt-8 overflow-hidden bg-paper py-8 md:py-10">
    <div class="clients-track flex w-max items-center gap-12 px-6 md:gap-16" id="clientsTrack">
      {
        loop.map((cl) =>
          cl.logo ? (
            <img
              src={`/clients/${cl.slug}.png`}
              alt={cl.name}
              loading="lazy"
              decoding="async"
              class="client-logo h-12 w-auto shrink-0 object-contain md:h-16"
            />
          ) : (
            <span class="shrink-0 select-none whitespace-nowrap text-base font-semibold tracking-tight text-ink/75 md:text-lg">
              {cl.name}
            </span>
          ),
        )
      }
    </div>
  </div>
</section>

<style>
  .clients-mask {
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
  }
  .client-logo {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @media (pointer: fine) {
    .client-logo:hover { transform: scale(1.08); }
  }
</style>
