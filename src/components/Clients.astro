---
import type { Lang } from "../lib/i18n";
import { CLIENTS } from "../lib/clients";
const { lang } = Astro.props as { lang: Lang };

const T: Record<Lang, { eyebrow: string; title: string }> = {
  uz: { eyebrow: "Mijozlar", title: "Bizga ishonadigan tashkilotlar" },
  ru: { eyebrow: "Клиенты", title: "Организации, которые нам доверяют" },
  en: { eyebrow: "Clients", title: "Organisations that trust us" },
  kk: { eyebrow: "Клиенттер", title: "Бізге сенетін ұйымдар" },
  ky: { eyebrow: "Кардарлар", title: "Бизге ишенген уюмдар" },
  tg: { eyebrow: "Муштариён", title: "Ташкилотҳое, ки ба мо бовар мекунанд" },
};
const c = T[lang];
// Doubled for a seamless infinite loop (GSAP shifts the track by -50%).
const loop = [...CLIENTS, ...CLIENTS];
---

<section id="clients" class="border-t border-hairline py-14 md:py-16">
  <div class="container-x">
    <div class="reveal max-w-prose">
      <span class="eyebrow">{c.eyebrow}</span>
      <h2 class="mt-3 text-xl font-medium tracking-tight md:text-2xl">{c.title}</h2>
    </div>
  </div>

  <!-- White rail so brand-coloured client logos read on the dark page. -->
  <div class="clients-mask relative mt-8 overflow-hidden bg-paper py-6 md:py-7">
    <div class="clients-track flex w-max items-center gap-10 px-6 md:gap-14" id="clientsTrack">
      {
        loop.map((cl) =>
          cl.logo ? (
            <img
              src={`/clients/${cl.slug}.png`}
              alt={cl.name}
              loading="lazy"
              decoding="async"
              class="client-logo h-9 w-auto shrink-0 object-contain md:h-11"
            />
          ) : (
            <span class="shrink-0 select-none whitespace-nowrap text-base font-semibold tracking-tight text-ink/75 md:text-lg">
              {cl.name}
            </span>
          ),
        )
      }
    </div>
  </div>
</section>

<style>
  .clients-mask {
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
  }
  .client-logo {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @media (pointer: fine) {
    .client-logo:hover { transform: scale(1.08); }
  }
</style>
