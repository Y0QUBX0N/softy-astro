const T: Record<Lang, Copy> = {
  uz: {
    eyebrow: "Xizmatlar",
    title: "Korxonangiz uchun to'liq IT-yechimlar",
    sub: "Litsenziyadan kiberxavfsizlik, cloud va infratuzilmagacha — barchasini bir integrator orqali yetkazamiz, joriy qilamiz va qo'llab-quvvatlaymiz.",
    cta: "Bog'lanish",
    items: [
      { title: "Litsenziyalash va obuna", desc: "Microsoft, Adobe, Autodesk va boshqa vendorlardan rasmiy litsenziyalarni tanlash, yetkazib berish va boshqarish." },
      { title: "Kiberxavfsizlik", desc: "Firewall, endpoint himoya, DLP va pochta xavfsizligi — Fortinet, Palo Alto, Kaspersky asosida joriy qilamiz." },
      { title: "Bulutli yechimlar", desc: "Google Cloud va Microsoft 365 / Azure — migratsiya, sozlash va boshqaruv." },
      { title: "Server va tarmoq infratuzilma", desc: "Server, storage va tarmoq uskunalarini tanlash, o'rnatish va sozlash." },
      { title: "Backup va tiklash", desc: "Veeam asosida zaxira nusxa va avariyadan tiklash — ma'lumotlaringiz xavfsiz." },
      { title: "Biznes ilovalar va CRM", desc: "Bitrix24 va ClickUp — biznes jarayonlarni avtomatlashtirish va joriy qilish." },
      { title: "Dizayn va muhandislik", desc: "Autodesk, nanoCAD, LIRA-FEM, IDEA StatiCa — CAD/BIM litsenziya va qo'llab-quvvatlash." },
      { title: "IT support va autsorsing", desc: "O'rnatishdan keyin ham — 24/7 texnik yordam, migratsiya va doimiy boshqaruv." },
    ],
  },
  ru: {
    eyebrow: "Услуги",
    title: "Полный спектр IT-решений для бизнеса",
    sub: "От лицензирования до кибербезопасности, облака и инфраструктуры — поставляем, внедряем и поддерживаем всё через одного интегратора.",
    cta: "Связаться",
    items: [
      { title: "Лицензирование и подписки", desc: "Подбор, поставка и управление официальными лицензиями Microsoft, Adobe, Autodesk и других вендоров." },
      { title: "Кибербезопасность", desc: "Firewall, защита конечных устройств, DLP и безопасность почты — на базе Fortinet, Palo Alto, Kaspersky." },
      { title: "Облачные решения", desc: "Google Cloud и Microsoft 365 / Azure — миграция, настройка и управление." },
      { title: "Серверы и сетевая инфраструктура", desc: "Подбор, установка и настройка серверов, хранилищ и сетевого оборудования." },
      { title: "Резервное копирование и DR", desc: "Резервное копирование и аварийное восстановление на базе Veeam — ваши данные защищены." },
      { title: "Бизнес-приложения и CRM", desc: "Bitrix24 и ClickUp — автоматизация и внедрение бизнес-процессов." },
      { title: "Проектирование и инженерия", desc: "Autodesk, nanoCAD, LIRA-FEM, IDEA StatiCa — лицензии CAD/BIM и поддержка." },
      { title: "IT-поддержка и аутсорсинг", desc: "После внедрения — техподдержка 24/7, миграция и постоянное управление." },
    ],
  },
  en: {
    eyebrow: "Services",
    title: "End-to-end IT solutions for your business",
    sub: "From licensing to cybersecurity, cloud and infrastructure — we supply, deploy and support it all through one integrator.",
    cta: "Get in touch",
    items: [
      { title: "Licensing & subscriptions", desc: "Selecting, supplying and managing official licenses from Microsoft, Adobe, Autodesk and other vendors." },
      { title: "Cybersecurity", desc: "Firewall, endpoint protection, DLP and email security — built on Fortinet, Palo Alto, Kaspersky." },
      { title: "Cloud solutions", desc: "Google Cloud and Microsoft 365 / Azure — migration, setup and management." },
      { title: "Servers & network infrastructure", desc: "Selecting, installing and configuring servers, storage and network hardware." },
      { title: "Backup & disaster recovery", desc: "Backup and disaster recovery powered by Veeam — your data stays safe." },
      { title: "Business applications & CRM", desc: "Bitrix24 and ClickUp — automating and deploying business processes." },
      { title: "Design & engineering", desc: "Autodesk, nanoCAD, LIRA-FEM, IDEA StatiCa — CAD/BIM licensing and support." },
      { title: "IT support & outsourcing", desc: "Beyond deployment — 24/7 technical support, migration and ongoing management." },
    ],
  },
  kk: {
    eyebrow: "Қызметтер",
    title: "Бизнесіңіз үшін толық IT-шешімдер",
    sub: "Лицензиялаудан киберқауіпсіздік, бұлт және инфрақұрылымға дейін — барлығын бір интегратор арқылы жеткіземіз, енгіземіз және қолдаймыз.",
    cta: "Байланысу",
    items: [
      { title: "Лицензиялау және жазылым", desc: "Microsoft, Adobe, Autodesk және басқа вендорлардан ресми лицензияларды таңдау, жеткізу және басқару." },
      { title: "Киберқауіпсіздік", desc: "Firewall, endpoint қорғау, DLP және пошта қауіпсіздігі — Fortinet, Palo Alto, Kaspersky негізінде." },
      { title: "Бұлттық шешімдер", desc: "Google Cloud және Microsoft 365 / Azure — көшіру, баптау және басқару." },
      { title: "Сервер және желілік инфрақұрылым", desc: "Сервер, сақтау және желілік жабдықты таңдау, орнату және баптау." },
      { title: "Резервтік көшіру және қалпына келтіру", desc: "Veeam негізінде резервтік көшіру және апаттан қалпына келтіру — деректеріңіз қорғалған." },
      { title: "Бизнес-қосымшалар және CRM", desc: "Bitrix24 және ClickUp — бизнес-процестерді автоматтандыру және енгізу." },
      { title: "Жобалау және инженерия", desc: "Autodesk, nanoCAD, LIRA-FEM, IDEA StatiCa — CAD/BIM лицензиялары және қолдау." },
      { title: "IT қолдау және аутсорсинг", desc: "Енгізуден кейін де — 24/7 техникалық қолдау, көшіру және тұрақты басқару." },
    ],
  },
  ky: {
    eyebrow: "Кызматтар",
    title: "Бизнесиңиз үчүн толук IT-чечимдер",
    sub: "Лицензиялоодон киберкоопсуздук, булут жана инфраструктурага чейин — баарын бир интегратор аркылуу жеткиребиз, киргизебиз жана колдойбуз.",
    cta: "Байланышуу",
    items: [
      { title: "Лицензиялоо жана жазылуу", desc: "Microsoft, Adobe, Autodesk жана башка вендорлордон расмий лицензияларды тандоо, жеткирүү жана башкаруу." },
      { title: "Киберкоопсуздук", desc: "Firewall, endpoint коргоо, DLP жана почта коопсуздугу — Fortinet, Palo Alto, Kaspersky негизинде." },
      { title: "Булут чечимдери", desc: "Google Cloud жана Microsoft 365 / Azure — миграция, тууралоо жана башкаруу." },
      { title: "Сервер жана тармак инфраструктура", desc: "Сервер, сактагыч жана тармак жабдууларын тандоо, орнотуу жана тууралоо." },
      { title: "Камдык көчүрүү жана калыбына келтирүү", desc: "Veeam негизинде камдык көчүрүү жана кырсыктан калыбына келтирүү — маалыматыңыз коопсуз." },
      { title: "Бизнес-тиркемелер жана CRM", desc: "Bitrix24 жана ClickUp — бизнес-процесстерди автоматташтыруу жана киргизүү." },
      { title: "Долбоорлоо жана инженерия", desc: "Autodesk, nanoCAD, LIRA-FEM, IDEA StatiCa — CAD/BIM лицензиялары жана колдоо." },
      { title: "IT колдоо жана аутсорсинг", desc: "Киргизгенден кийин да — 24/7 техникалык колдоо, миграция жана туруктуу башкаруу." },
    ],
  },
  tg: {
    eyebrow: "Хидматҳо",
    title: "Ҳалли мукаммали IT барои бизнеси шумо",
    sub: "Аз литсензиякунонӣ то киберамният, абр ва инфрасохтор — ҳамаро тавассути як интегратор таъмин, ҷорӣ ва дастгирӣ мекунем.",
    cta: "Тамос",
    items: [
      { title: "Литсензиякунонӣ ва обуна", desc: "Интихоб, таъмин ва идоракунии литсензияҳои расмии Microsoft, Adobe, Autodesk ва дигар вендорҳо." },
      { title: "Киберамният", desc: "Firewall, ҳифзи endpoint, DLP ва амнияти почта — дар асоси Fortinet, Palo Alto, Kaspersky." },
      { title: "Ҳалли абрӣ", desc: "Google Cloud ва Microsoft 365 / Azure — муҳоҷират, танзим ва идоракунӣ." },
      { title: "Сервер ва инфрасохтори шабака", desc: "Интихоб, насб ва танзими сервер, захира ва таҷҳизоти шабака." },
      { title: "Нусхабардорӣ ва барқарорсозӣ", desc: "Нусхабардорӣ ва барқарорсозии офат дар асоси Veeam — додаҳои шумо бехатаранд." },
      { title: "Барномаҳои тиҷоратӣ ва CRM", desc: "Bitrix24 ва ClickUp — автоматизатсия ва ҷорисозии равандҳои тиҷоратӣ." },
      { title: "Тарроҳӣ ва муҳандисӣ", desc: "Autodesk, nanoCAD, LIRA-FEM, IDEA StatiCa — литсензияҳои CAD/BIM ва дастгирӣ." },
      { title: "Дастгирии IT ва аутсорсинг", desc: "Пас аз ҷорисозӣ низ — дастгирии техникии 24/7, муҳоҷират ва идоракунии доимӣ." },
    ],
  },
