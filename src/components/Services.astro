// Line icons, indexed to the 8 service lines above.
const ICONS = [
  '<path d="M14 3v4a1 1 0 0 0 1 1h4"/><path d="M17 21H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2z"/><path d="M9 14l2 2 4-4"/>',
  '<path d="M12 3l8 4v5c0 5-3.5 8-8 9-4.5-1-8-4-8-9V7z"/><path d="M9 12l2 2 4-4"/>',
  '<path d="M17.5 19a4.5 4.5 0 0 0 .5-9 6 6 0 0 0-11.5 1.5A4 4 0 0 0 7 19z"/>',
  '<rect x="3" y="4" width="18" height="6" rx="1.5"/><rect x="3" y="14" width="18" height="6" rx="1.5"/><path d="M7 7h.01M7 17h.01"/>',
  '<ellipse cx="12" cy="6" rx="8" ry="3"/><path d="M4 6v12c0 1.7 3.6 3 8 3s8-1.3 8-3V6"/><path d="M4 12c0 1.7 3.6 3 8 3s8-1.3 8-3"/>',
  '<rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/>',
  '<path d="M14 4l6 6-11 11H3v-6z"/><path d="M12 6l6 6"/>',
  '<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3.5"/><path d="M5 5l4.5 4.5M14.5 14.5L19 19M19 5l-4.5 4.5M9.5 14.5L5 19"/>',
];

const c = T[lang];
const contactHref = pageUrl(lang, "contact");
---

<section id="services" class="bg-paper text-ink">
  <div class="container-x py-24 md:py-32">
    {!hideHeader && (
      <div class="reveal flex flex-wrap items-end justify-between gap-6">
        <div class="max-w-2xl">
          <span class="eyebrow" style="color:#06b08a">{c.eyebrow}</span>
          <h2 class="h2 mt-5 text-balance" style="color:#0E1014">{c.title}</h2>
          <p class="body-lg mt-6 max-w-prose text-ink/70">{c.sub}</p>
        </div>
        <a href={contactHref} class="btn btn-dark h-11 px-5 text-sm" data-cursor>
          {c.cta}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
        </a>
      </div>
    )}

    <div data-stagger class={`grid gap-5 sm:grid-cols-2 lg:grid-cols-4 ${hideHeader ? "" : "mt-16"}`}>
      {
        c.items.map((s, i) => (
          <article class="group flex flex-col gap-4 rounded-2xl border border-hairline-dark bg-white p-7 transition-all duration-500 hover:-translate-y-1 hover:border-accent-deep/40 hover:shadow-[0_24px_50px_-24px_rgba(6,176,138,0.35)]">
            <span class="grid h-12 w-12 place-items-center rounded-xl border border-hairline-dark text-accent-deep transition-colors duration-300 group-hover:border-accent-deep/50 group-hover:bg-accent-deep/8">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS[i]} />
            </span>
            <h3 class="text-[19px] font-semibold leading-tight tracking-tight" style="color:#0E1014">{s.title}</h3>
            <p class="text-[15px] leading-relaxed text-ink/65">{s.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
