---
import { type Lang } from "../lib/i18n";
import { pageUrl } from "../lib/nav";
const { lang, hideHeader = false } = Astro.props as { lang: Lang; hideHeader?: boolean };

interface Svc { title: string; desc: string }
interface Copy { eyebrow: string; title: string; sub: string; cta: string; items: Svc[] }

