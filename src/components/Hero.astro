---
import { getContent, type Lang } from "../lib/i18n";
import { pageUrl } from "../lib/nav";
import HeroConstellation from "./HeroConstellation.tsx";
const { lang } = Astro.props as { lang: Lang };
const c = getContent(lang);
const contactHref = pageUrl(lang, "contact");
const wordsA = c.hero.titleA.split(" ");
const wordsAccent = c.hero.titleAccent.split(" ");
---

<section id="hero" class="relative flex min-h-[100svh] flex-col overflow-hidden pt-[68px]">
  <!-- ambient base wash (sits behind the constellation) -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div class="hero-base absolute inset-0"></div>
  </div>
  <!-- Interactive constellation: 26 vendor "stars" linked into a slowly
       drifting, cursor-reactive mesh. Pure Canvas 2D; hydrates on idle so it
       never blocks the hero's first paint. -->
  <div class="hero-constellation pointer-events-none absolute inset-0 -z-[5]" aria-hidden="true">
    <HeroConstellation client:idle />
  </div>
  <!-- Legibility scrim: darkens the text column + the lower band so the
       headline stays crisp over the mesh. Clears toward the right so the
       constellation stays visible where there's no copy. -->
  <div class="hero-scrim pointer-events-none absolute inset-0 -z-[4]" aria-hidden="true"></div>

  <div class="container-x relative flex flex-1 flex-col justify-center py-16">
    <div class="max-w-[920px]">
      <span class="reveal eyebrow inline-flex items-center gap-2">
        <span class="relative flex h-1.5 w-1.5">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent opacity-75"></span>
          <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-accent"></span>
        </span>
        {c.hero.eyebrow}
      </span>

      <h1 class="display mt-6">
        {wordsA.map((word) => (
          <span class="hero-word inline-block overflow-hidden align-bottom"><span class="hero-word-inner inline-block">{word}&nbsp;</span></span>
        ))}
        <span class="text-accent">
          {wordsAccent.map((word) => (
            <span class="hero-word inline-block overflow-hidden align-bottom"><span class="hero-word-inner inline-block">{word}&nbsp;</span></span>
          ))}
        </span>
      </h1>

      <p class="reveal body-xl mt-9 max-w-[660px] text-primary/90">
        {c.hero.lead}
      </p>

      <div class="reveal mt-10 flex flex-wrap items-center gap-4">
        <a href={contactHref} class="btn btn-accent" data-cursor data-magnetic="0.3">
          {c.hero.ctaPrimary}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
        </a>
        <a href="#vendors" class="btn btn-ghost" data-cursor>{c.hero.ctaSecondary}</a>
      </div>
    </div>
  </div>

  <!-- trust micro-bar -->
  <div class="reveal hero-trust border-t border-hairline">
    <div class="container-x flex flex-wrap items-center gap-x-8 gap-y-2 py-5 text-[15px] text-muted">
      {c.hero.trust.map((t, i) => (
        <>
          {i > 0 && <span class="hidden h-1 w-1 rounded-full bg-muted/50 sm:inline-block"></span>}
          <span class="flex items-center gap-2">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#00D9A3" stroke-width="2.5"><path d="M20 6L9 17l-5-5" /></svg>
            {t}
          </span>
        </>
      ))}
    </div>
  </div>
</section>

<style>
  /* Base wash: brand-green accent (top-right) + a hint of the Softy brand blue
     (bottom-left) for depth — tuned subtle so text stays crisp. */
  .hero-base {
    background:
      radial-gradient(120% 110% at 80% 12%, rgba(0, 217, 163, 0.14) 0%, rgba(14, 16, 20, 0) 55%),
      radial-gradient(95% 85% at 8% 102%, rgba(34, 84, 220, 0.12) 0%, rgba(14, 16, 20, 0) 52%),
      linear-gradient(180deg, rgba(16, 19, 26, 0) 60%, rgba(10, 12, 16, 0.9) 100%);
  }

  /* Text legibility scrim — heavier on the left/lower text column, clears on
     the right so the constellation mesh stays visible. */
  .hero-scrim {
    background:
      linear-gradient(95deg, rgba(9, 11, 15, 0.86) 0%, rgba(9, 11, 15, 0.52) 34%, rgba(9, 11, 15, 0.12) 58%, rgba(9, 11, 15, 0) 76%),
      linear-gradient(0deg, rgba(8, 10, 14, 0.55) 0%, rgba(8, 10, 14, 0) 42%);
  }

  /* Constellation colours — swap these to re-theme the canvas mesh. */
  .hero-constellation {
    --c-accent: #00d9a3; /* dots + links */
    --c-label: #f5f2ec; /* vendor labels */
  }
</style>
