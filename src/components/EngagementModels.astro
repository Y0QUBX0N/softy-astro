---
import { getContent, type Lang } from "../lib/i18n";
import { pageUrl } from "../lib/nav";
const { lang } = Astro.props as { lang: Lang };
const c = getContent(lang);
const e = c.engagement;
const contactHref = pageUrl(lang, "contact");
---

<section id="engagement" class="bg-paper text-ink">
  <div class="container-x py-24 md:py-32">
    <div class="reveal mx-auto max-w-2xl text-center">
      <span class="eyebrow" style="color:#06b08a">{e.eyebrow}</span>
      <h2 class="h2 mt-5" style="color:#0E1014">{e.title}</h2>
      <p class="body-lg mt-5 text-ink/70">{e.sub}</p>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-3">
      {
        e.models.map((m) => (
          <div
            class={`relative flex flex-col rounded-lg border p-8 ${m.highlight ? "reveal border-accent bg-ink text-primary shadow-[0_24px_60px_-24px_rgba(0,217,163,0.45)]" : "reveal border-hairline-dark bg-white"}`}
          >
            {m.tag && (
              <span class="absolute -top-3 left-8 rounded bg-accent px-3 py-1 text-xs font-semibold uppercase tracking-wider text-ink">
                {m.tag}
              </span>
            )}
            <div class={`text-sm font-semibold uppercase tracking-wider ${m.highlight ? "text-accent" : "text-ink/50"}`}>
              {m.name}
            </div>
            <p class={`mt-3 text-[15px] leading-relaxed ${m.highlight ? "text-primary/80" : "text-ink/68"}`}>{m.desc}</p>

            <div class="mt-7">
              <span class={`text-3xl font-semibold tracking-tight ${m.highlight ? "text-primary" : "text-ink"}`}>{e.customLabel}</span>
              <div class={`mt-1 text-xs ${m.highlight ? "text-accent" : "text-accent-deep"}`}>{e.note}</div>
            </div>

            <ul class="mt-8 flex flex-1 flex-col gap-3">
              {m.features.map((f) => (
                <li class={`flex items-start gap-3 text-[15px] ${m.highlight ? "text-primary/85" : "text-ink/78"}`}>
                  <svg class="mt-0.5 shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={m.highlight ? "#00D9A3" : "#06b08a"} stroke-width="2.5"><path d="M20 6L9 17l-5-5" /></svg>
                  <span>{f}</span>
                </li>
              ))}
            </ul>

            <a href={contactHref} data-cursor class={`btn mt-8 w-full ${m.highlight ? "btn-accent" : "btn-dark"}`}>
              {m.cta}
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
