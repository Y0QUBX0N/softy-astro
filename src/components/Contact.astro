---
import { getContent, type Lang } from "../lib/i18n";
const { lang, hideHeader = false } = Astro.props as { lang: Lang; hideHeader?: boolean };
const c = getContent(lang);
const f = c.contact.form;
---

<section id="contact" class={`${hideHeader ? "" : "border-t border-hairline"} py-24 md:py-32`}>
  <div class="container-x grid gap-14 lg:grid-cols-2 lg:gap-24">
    <!-- info -->
    <div class="reveal">
      {!hideHeader && (
        <>
          <span class="eyebrow">{c.contact.eyebrow}</span>
          <h2 class="h2 mt-5 text-balance">{c.contact.title}</h2>
          <p class="body-lg mt-6 max-w-prose text-secondary">{c.contact.sub}</p>
        </>
      )}

      <div class={`flex flex-col gap-7 ${hideHeader ? "" : "mt-12"}`}>
        <a href="tel:+998956400404" class="group flex items-center gap-4" data-cursor>
          <span class="grid h-11 w-11 place-items-center rounded border border-hairline text-accent transition-colors group-hover:border-accent/50">
            <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 16.9v3a2 2 0 01-2.2 2 19.8 19.8 0 01-8.6-3 19.5 19.5 0 01-6-6 19.8 19.8 0 01-3-8.6A2 2 0 014.1 2h3a2 2 0 012 1.7c.1.9.3 1.8.6 2.6a2 2 0 01-.5 2.1L8.1 9.5a16 16 0 006 6l1.1-1.1a2 2 0 012.1-.5c.8.3 1.7.5 2.6.6a2 2 0 011.7 2z" /></svg>
          </span>
          <span>
            <span class="block text-xs uppercase tracking-eyebrow text-muted">{c.contact.phoneLabel}</span>
            <span class="block text-lg font-medium transition-colors group-hover:text-accent">+998 (95) 640-04-04</span>
          </span>
        </a>

        <a href="mailto:info@softy.uz" class="group flex items-center gap-4" data-cursor>
          <span class="grid h-11 w-11 place-items-center rounded border border-hairline text-accent transition-colors group-hover:border-accent/50">
            <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="4" width="20" height="16" rx="2" /><path d="M22 7l-10 6L2 7" /></svg>
          </span>
          <span>
            <span class="block text-xs uppercase tracking-eyebrow text-muted">{c.contact.emailLabel}</span>
            <span class="block text-lg font-medium transition-colors group-hover:text-accent">info@softy.uz</span>
          </span>
        </a>

        <a href="https://t.me/Softy_admin" target="_blank" rel="noopener" class="group flex items-center gap-4" data-cursor>
          <span class="grid h-11 w-11 place-items-center rounded border border-hairline text-accent transition-colors group-hover:border-accent/50">
            <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor"><path d="M21.5 4L2.5 11.5l6 2 2.5 7 3-4.5 5 4z" /></svg>
          </span>
          <span>
            <span class="block text-xs uppercase tracking-eyebrow text-muted">{c.contact.tgLabel}</span>
            <span class="block text-lg font-medium transition-colors group-hover:text-accent">@Softy_admin</span>
          </span>
        </a>

        <div class="flex items-start gap-4 pt-2">
          <span class="grid h-11 w-11 shrink-0 place-items-center rounded border border-hairline text-accent">
            <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0116 0z" /><circle cx="12" cy="10" r="3" /></svg>
          </span>
          <span>
            <span class="block text-xs uppercase tracking-eyebrow text-muted">{c.contact.addrLabel}</span>
            <span class="block max-w-xs leading-relaxed text-primary/90">{c.contact.address}</span>
            <span class="mt-2 block text-sm text-muted">{c.contact.hours}</span>
          </span>
        </div>
      </div>
    </div>

    <!-- form -->
    <form
      class="reveal flex flex-col gap-7"
      id="contactForm"
      action="/api/contact/"
      method="POST"
      novalidate
      data-sending={f.sending}
      data-error={f.error}
    >
      <input type="hidden" name="lang" value={lang} />
      <input type="hidden" name="page" value="contact" />
      <!-- honeypot: hidden from users, catches bots -->
      <div aria-hidden="true" class="absolute left-[-9999px] h-0 w-0 overflow-hidden">
        <label>Company<input type="text" name="company" tabindex="-1" autocomplete="off" /></label>
      </div>

      <div id="formSuccess" class="hidden items-center gap-3 rounded border border-accent/40 bg-accent/10 px-4 py-3 text-sm text-accent" role="status" aria-live="polite">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5" /></svg>
        <span>{f.success}</span>
      </div>
      <div id="formError" class="hidden items-center gap-3 rounded border border-red-400/40 bg-red-400/10 px-4 py-3 text-sm text-red-300" role="alert" aria-live="assertive">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 8v5M12 16.5v.5M10.3 3.9 2.4 18a1.6 1.6 0 0 0 1.4 2.4h16.4a1.6 1.6 0 0 0 1.4-2.4L13.7 3.9a1.6 1.6 0 0 0-2.8 0Z" /></svg>
        <span id="formErrorMsg">{f.error}</span>
      </div>

      <div class="grid gap-7 sm:grid-cols-2">
        <label class="field-line">
          <span>{f.name}</span>
          <input type="text" name="name" required placeholder={f.namePh} />
        </label>
        <label class="field-line">
          <span>{f.phone}</span>
          <input type="tel" name="phone" required placeholder={f.phonePh} />
        </label>
      </div>
      <label class="field-line">
        <span>{f.email}</span>
        <input type="email" name="email" placeholder={f.emailPh} />
      </label>
      <label class="field-line">
        <span>{f.message}</span>
        <textarea name="message" rows="4" placeholder={f.messagePh}></textarea>
      </label>
      <button type="submit" id="formSubmit" class="btn btn-accent self-start disabled:opacity-60" data-cursor>
        <span id="formSubmitLabel" data-default={f.submit}>{f.submit}</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
      </button>
    </form>
  </div>
</section>

<style>
  .field-line {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .field-line > span {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: #aab0bb;
  }
  .field-line input,
  .field-line textarea {
    background: transparent;
    border: 0;
    border-bottom: 1px solid rgba(245, 242, 236, 0.18);
    padding: 11px 2px;
    color: #f5f2ec;
    font-size: 16.5px;
    transition: border-color 0.3s;
    resize: vertical;
  }
  .field-line input::placeholder,
  .field-line textarea::placeholder {
    color: rgba(154, 160, 173, 0.6);
  }
  .field-line input:focus,
  .field-line textarea:focus {
    outline: none;
    border-color: #00d9a3;
  }
</style>
