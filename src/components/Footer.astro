---
import { getContent, type Lang, type PageKey } from "../lib/i18n";
import { pageUrl } from "../lib/nav";
import { LEGAL_LABELS } from "../lib/legal";
import LangSwitcher from "./LangSwitcher.astro";
const { lang, page } = Astro.props as { lang: Lang; page: PageKey };
const c = getContent(lang);
const legal = LEGAL_LABELS[lang];
const home = pageUrl(lang, "home");
const year = new Date().getUTCFullYear();

const socials = [
  { label: "Telegram", href: "https://t.me/Softy_admin", path: '<path d="M21.5 4L2.5 11.5l6 2 2.5 7 3-4.5 5 4z"/>' },
  { label: "LinkedIn", href: "https://www.linkedin.com/company/softysolution", path: '<rect x="2" y="2" width="20" height="20" rx="2"/><path d="M7 10v7M7 7v.01M12 17v-4a2 2 0 014 0v4" stroke="#0E1014" fill="none" stroke-width="2"/>' },
  { label: "Instagram", href: "https://www.instagram.com/softy_group/", path: '<rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4" stroke="#0E1014" fill="none" stroke-width="2"/><circle cx="17" cy="7" r="1" fill="#0E1014"/>' },
  { label: "YouTube", href: "https://youtube.com/@softy", path: '<rect x="2" y="5" width="20" height="14" rx="4"/><path d="M10 9l5 3-5 3z" fill="#0E1014"/>' },
];
---

<footer class="relative overflow-hidden border-t border-hairline bg-ink pt-20">
  <div class="container-x relative z-10">
    <div class="grid gap-12 pb-16 md:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <!-- brand -->
      <div>
        <a href={pageUrl(lang, "home")} class="flex items-center" aria-label="Softy LLC">
          <img src="/softy-logo-white.svg" alt="Softy" width="128" height="30" class="h-[30px] w-auto" />
        </a>
        <p class="mt-5 max-w-xs text-sm leading-relaxed text-muted">{c.footer.tagline}</p>
        <div class="mt-7 flex flex-wrap gap-2.5">
          {
            socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener"
                aria-label={s.label}
                data-cursor
                class="social-pill group flex h-10 items-center gap-0 overflow-hidden rounded border border-hairline px-2.5 text-muted transition-all duration-300 hover:border-accent/50 hover:text-accent"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" set:html={s.path} />
                <span class="max-w-0 overflow-hidden whitespace-nowrap text-sm opacity-0 transition-all duration-300 group-hover:ml-2 group-hover:max-w-[120px] group-hover:opacity-100">
                  {s.label}
                </span>
              </a>
            ))
          }
        </div>
      </div>

      <!-- services -->
      <div>
        <h3 class="text-xs uppercase tracking-eyebrow text-muted">{c.footer.servicesCol}</h3>
        <ul class="mt-5 flex flex-col gap-3">
          {c.pillars.items.map((p) => (
            <li><a href={pageUrl(lang, "services")} class="text-sm text-primary/80 transition-colors hover:text-accent">{p.title}</a></li>
          ))}
        </ul>
      </div>

      <!-- company -->
      <div>
        <h3 class="text-xs uppercase tracking-eyebrow text-muted">{c.footer.companyCol}</h3>
        <ul class="mt-5 flex flex-col gap-3">
          <li><a href={pageUrl(lang, "solutions")} class="text-sm text-primary/80 transition-colors hover:text-accent">{c.nav.solutions}</a></li>
          <li><a href={pageUrl(lang, "coverage")} class="text-sm text-primary/80 transition-colors hover:text-accent">{c.nav.coverage}</a></li>
          <li><a href={pageUrl(lang, "about")} class="text-sm text-primary/80 transition-colors hover:text-accent">{c.nav.about}</a></li>
          <li><a href={pageUrl(lang, "contact")} class="text-sm text-primary/80 transition-colors hover:text-accent">{c.nav.contact}</a></li>
        </ul>
      </div>

      <!-- contact -->
      <div>
        <h3 class="text-xs uppercase tracking-eyebrow text-muted">{c.footer.contactCol}</h3>
        <ul class="mt-5 flex flex-col gap-3 text-sm">
          <li><a href="tel:+998956400404" class="text-primary/80 transition-colors hover:text-accent">+998 (95) 640-04-04</a></li>
          <li><a href="mailto:info@softy.uz" class="text-primary/80 transition-colors hover:text-accent">info@softy.uz</a></li>
          <li><a href="https://t.me/Softy_admin" target="_blank" rel="noopener" class="text-primary/80 transition-colors hover:text-accent">@Softy_admin</a></li>
          <li class="max-w-[200px] leading-relaxed text-muted">{c.contact.address}</li>
        </ul>
      </div>
    </div>

    <div class="flex flex-col gap-5 border-t border-hairline py-7 lg:flex-row lg:items-center lg:justify-between">
      <span class="text-sm text-muted">© {year} Softy LLC. {c.footer.rights}</span>
      <div class="flex flex-wrap items-center gap-x-6 gap-y-3 text-sm">
        <a href={`${home}privacy/`} class="text-muted transition-colors hover:text-accent">{legal.privacy}</a>
        <a href={`${home}terms/`} class="text-muted transition-colors hover:text-accent">{legal.terms}</a>
        <span class="text-muted">softy.uz</span>
        <LangSwitcher lang={lang} page={page} align="right" />
      </div>
    </div>
  </div>

  <!-- giant outlined wordmark -->
  <div class="pointer-events-none relative select-none" aria-hidden="true">
    <div
      id="footerWord"
      class="wordmark-outline whitespace-nowrap text-center font-semibold leading-none"
      style="font-size:clamp(80px,26vw,420px);letter-spacing:-0.04em;margin-bottom:-0.12em"
      data-parallax="0.5"
    >
      Softy
    </div>
  </div>
</footer>

<style>
  .wordmark-outline {
    color: transparent;
    -webkit-text-stroke: 1px rgba(245, 242, 236, 0.08);
    transition: -webkit-text-stroke-color 0.5s;
  }
</style>
