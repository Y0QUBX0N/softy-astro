# ─────────────────────────────────────────────────────────────
# Softy LLC — runtime configuration (server-side only)
# Copy to `.env` and fill in. NEVER commit the real `.env`.
# The /api/contact endpoint reads these at runtime (process.env).
# ─────────────────────────────────────────────────────────────

# ── Telegram delivery ──────────────────────────────────────
# 1) Create a bot via @BotFather → get the token.
# 2) Get your chat id (e.g. via @userinfobot) or a group/channel id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email delivery (SMTP) ──────────────────────────────────
# Any provider with SMTP works (e.g. Mailgun, SendGrid, Resend,
# Yandex 360, Google Workspace, your hosting). Backup channel that
# kicks in if Telegram fails or is not configured.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Softy LLC <noreply@softy.uz>
LEAD_EMAIL_TO=info@softy.uz

# ── Optional webhook (CRM / Zapier / Make / Apps Script) ──
LEAD_WEBHOOK_URL=

# ── Optional analytics (privacy-friendly) ──────────────────
# Set the Plausible domain (usually "softy.uz") to enable; leave
# blank to disable analytics entirely. Loaded only on the client.
PUBLIC_PLAUSIBLE_DOMAIN=

# ─────────────────────────────────────────────────────────────
# Notes
#   • If NO delivery channel is configured, leads still go to
#     ./data/leads.jsonl so nothing is ever lost.
#   • The endpoint returns ok=true as soon as ONE channel succeeds.
#   • Variables prefixed PUBLIC_ are exposed to the browser bundle.
# ─────────────────────────────────────────────────────────────
